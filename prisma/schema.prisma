generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  materials Material[]
}

model Material {
  id         String      @id @default(uuid())
  userId     String
  title      String
  status     String      @default("processing") // processing, completed
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
  chunks     Chunk[]
  concepts   Concept[]
}

model Chunk {
  id         String   @id @default(uuid())
  materialId String
  content    String
  chunkIndex Int
  createdAt  DateTime        @default(now())
  material   Material        @relation(fields: [materialId], references: [id], onDelete: Cascade)
  embedding  ChunkEmbedding?
}

model ChunkEmbedding {
  id        String   @id @default(uuid())
  chunkId   String   @unique
  embedding String   // Storing JSON stringified vector array
  createdAt DateTime @default(now())
  chunk     Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id           String   @id @default(uuid())
  materialId   String
  questionText String
  answerText   String
  createdAt    DateTime @default(now())
  material     Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

model Concept {
  id          String   @id @default(uuid())
  materialId  String
  name        String
  description String
  createdAt   DateTime @default(now())

  material      Material              @relation(fields: [materialId], references: [id], onDelete: Cascade)
  sourceEdges   ConceptRelationship[] @relation("SourceConcept")
  targetEdges   ConceptRelationship[] @relation("TargetConcept")
}

model ConceptRelationship {
  id              String   @id @default(uuid())
  sourceConceptId String
  targetConceptId String
  relationshipType String   // e.g., "is a part of", "leads to"
  createdAt       DateTime @default(now())

  source Concept @relation("SourceConcept", fields: [sourceConceptId], references: [id], onDelete: Cascade)
  target Concept @relation("TargetConcept", fields: [targetConceptId], references: [id], onDelete: Cascade)

  @@unique([sourceConceptId, targetConceptId])
}
